{
  "name": "browsefleet",
  "version": "0.1.0",
  "description": "TypeScript SDK for the BrowseFleet cloud browser API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
